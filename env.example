# Docker host bindings.
# Keep MySQL/backend on 127.0.0.1 so cloud servers do not expose them publicly.
# Frontend is the public entrypoint; Nginx proxies /api and /uploads to backend.
FRONTEND_BIND_ADDRESS=0.0.0.0
FRONTEND_PORT=80
BACKEND_BIND_ADDRESS=127.0.0.1
BACKEND_PORT=8080
MYSQL_BIND_ADDRESS=127.0.0.1
MYSQL_PORT=3306

# MySQL container
MYSQL_DATABASE=smart_workspace
MYSQL_ROOT_PASSWORD=smart_workspace_root_password

# Backend datasource. Keep DB_USERNAME/DB_PASSWORD matching the MySQL user above.
DB_URL=jdbc:mysql://db:3306/smart_workspace?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Ho_Chi_Minh&useUnicode=true&characterEncoding=utf8
DB_USERNAME=smart_workspace
DB_PASSWORD=smart_workspace_password

# JWT
JWT_SECRET=change-this-secret-to-at-least-32-characters
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# Runtime URLs used by backend when it creates payment callback links.
APP_FRONTEND_URL=http://localhost
APP_PUBLIC_API_URL=http://localhost

# PayOS. Fill real values only when testing real PayOS checkout.
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_BASE_URL=https://api-merchant.payos.vn

# Frontend build variables.
VITE_API_BASE_URL=/api
VITE_ASSET_BASE_URL=

# Optional JVM tuning, for example: -Xms256m -Xmx512m
JAVA_OPTS=
