            "url": "{{baseUrl}}/api/products/{{productId}}/comments"
          }
        },
        {
          "name": "Create reply comment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{customerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Demo reply comment.\",\n  \"parentId\": {{commentId}}\n}"
            },
            "url": "{{baseUrl}}/api/products/{{productId}}/comments"
          }
        },
        {
          "name": "List comments",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/products/{{productId}}/comments"
          }
        },
        {
          "name": "Create feedback",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "if (body.data && body.data.id) { pm.collectionVariables.set('feedbackId', body.data.id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Demo Visitor\",\n  \"email\": \"visitor-{{runId}}@smartworkspace.local\",\n  \"phone\": \"0909000000\",\n  \"subject\": \"Tu van san pham\",\n  \"message\": \"Toi muon tu van combo setup cho phong nho.\"\n}"
            },
            "url": "{{baseUrl}}/api/feedbacks"
          }
        },
        {
          "name": "Admin update review status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"HIDDEN\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/reviews/{{reviewId}}/status"
          }
        },
        {
          "name": "Admin feedback list",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/admin/feedbacks?page=0&size=10"
          }
        },
        {
          "name": "Admin update feedback status",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"PROCESSING\"\n}"
            },
            "url": "{{baseUrl}}/api/admin/feedbacks/{{feedbackId}}/status"
          }
        }
      ]
    },
