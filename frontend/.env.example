# Backend URL used by the Vite dev proxy.
VITE_API_BASE_URL=/api

# Asset origin for backend paths such as /uploads/products/...
# Keep empty when frontend and backend share the same origin or Nginx proxies /uploads.
# Example for a separate API domain: https://api.smart-workspace.example
VITE_ASSET_BASE_URL=

# Only used by the Vite dev server.
VITE_DEV_API_TARGET=http://localhost:8080
