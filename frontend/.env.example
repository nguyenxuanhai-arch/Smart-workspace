# URL backend Spring Boot (Smart Workspace). Mặc định proxy qua vite.config.js nên không cần đổi khi chạy dev.
VITE_API_BASE_URL=/api

# Origin dùng để render ảnh backend trả về dạng /uploads/products/...
# Để trống khi frontend và backend cùng origin hoặc khi Nginx proxy /uploads.
# Ví dụ khi tách domain: https://api.smart-workspace.example
VITE_ASSET_BASE_URL=

# Chỉ dùng cho vite dev server khi chạy npm run dev.
VITE_DEV_API_TARGET=http://localhost:8080
